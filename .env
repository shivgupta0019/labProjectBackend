# Azure Configuration (optional - set if you want to enable Azure Mail service)
# Use valid UUIDs or leave empty
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_MAIL_SENDER=

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/centrallab

# JWT Configuration
JWT_SECRET=your_jwt_secret_key

# Node Environment
NODE_ENV=development
